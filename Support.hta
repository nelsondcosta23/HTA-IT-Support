<!DOCTYPE HTML>
<html lang="pt">

<head>
<title>IT Support Tool</title>
<HTA:Application
 ID = "HTA"
 ApplicationName = "IT Support Tool"
 Border = "thick"
 BorderStyle = "normal"
 Caption = "yes"
 ContextMenu="no"
 ICON=""
 InnerBorder="no"
 MaximizeButton = "no"
 MinimizeButton = "yes"
 Navigable="yes"
 Scroll="no"
 SrollFlat="no"
 Selection="yes"
 ShowInTaskBar = "yes"
 SingleInstance = "yes"
 SysMenu = "yes"
 Version = "1.6"
 WindowState = "normal"
>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<style type="text/css">
.ASL { font-family: Tahoma; font-size: small; }
.style1 { color: #FFFFFF; background-color: #000000; }
.style2 { color: #FFFFFF; font-size: large; background-color: #000000; font-family: Tahoma; }
.style3 { color: #FFFFFF; font-size: medium; background-color: #000000; }
body,td,th { font-family:Arial }
.head { font-size:110%; font-weight:bold }
.panel { background-color: white; border: solid 1px black; height: 430px; padding: 5px; z-index: 0; }
.tabs { border-collapse: collapse; color: black; cursor: pointer; cursor: hand; font-family: arial; font-size: 9pt; font-weight: bold; margin-top: 4px; padding: 2px 4px 0px 4px; position: relative; text-align: center; text-decoration: none; z-index: 1; }
.tabs0 { background-color: #f44336; border: solid 1px black; }
.tabs1 { background-color: white; border-color: black black white black; border-style: solid solid solid solid; border-width: 1px 1px 1px 1px; }
a:link { text-decoration: none; color: #f44336; }
a:visited { text-decoration: none; color: #f44336; }
a:hover { text-decoration: underline; color: #f44336; }
a:active { text-decoration: underline; color: #f44336; }
.button { background-color: #4CAF50; border: none; color: white; padding: 3px 6px; text-align: center; text-decoration: none; display: inline-block; font-size: 16px; margin: 4px 2px; -webkit-transition-duration: 0.4s; transition-duration: 0.4s; cursor: pointer; height: 35px; width: 170px; font-weight: bold; }
.button5 { background-color: white; color: black; border: 2px solid #555555; }
.button5:hover { background-color: #555555; color: white; }
.button1 { background-color: #f44336; color: black; border: 2px solid white; }
.button1:hover { background-color: #f44336; color: white; }
.creator-link { font-size: 10px; color: #888; }
.creator-link a { color: #888; text-decoration: none; }
.creator-link a:hover { text-decoration: underline; }
</style>
<script type="text/javascript">
self.moveTo(0,0);
self.resizeTo(1024,800);
var panels = new Array("","panel1","panel2","panel3","panel4");
function panel(tab) {
    for (i=1; i<panels.length; i++) {
        if (i == tab) {
            document.getElementById("tab"+i).className = "tabs tabs1";
            document.getElementById("panel"+i).style.display = "block";
        } else {
            document.getElementById("tab"+i).className = "tabs tabs0";
            document.getElementById("panel"+i).style.display = "none";
        }
    }
}
</script>
<script type="text/javascript">
    function computername() { var wshShell = new ActiveXObject("WScript.Shell"); return wshShell.ExpandEnvironmentStrings("%COMPUTERNAME%"); }
    function username() { var wshshell=new ActiveXObject("wscript.shell"); return wshshell.ExpandEnvironmentStrings("%username%"); }
	function ipAddress() { var ipAddress = ""; var wmi = GetObject("winmgmts:{impersonationLevel=impersonate}"); e = new Enumerator(wmi.ExecQuery("SELECT * FROM Win32_NetworkAdapterConfiguration WHERE IPEnabled = True")); for(; !e.atEnd(); e.moveNext()) { var s = e.item(); ipAddress = s.IPAddress(0); } return ipAddress }
	function macAddress() { var macAddress = ""; var wmi = GetObject("winmgmts:{impersonationLevel=impersonate}"); e = new Enumerator(wmi.ExecQuery("SELECT * FROM Win32_NetworkAdapterConfiguration WHERE IPEnabled = True")); for(; !e.atEnd(); e.moveNext()) { var s = e.item(); macAddress = s.MACAddress; } return macAddress }
var ip = ipAddress();
var mac = macAddress();
</script>
<script type="text/javascript">
  function link1() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
  function link2() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
  function link3() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
  function link4() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
  function link5() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
  function link6() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
  function link7() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
  function link8() { var shell = new ActiveXObject("WScript.Shell"); shell.run("https://www.google.com"); }
</script>
<script Language = VBScript>
On Error Resume Next
	Sub Window_OnLoad
		intWidth = 700
		intHeight = 620
		Me.ResizeTo intWidth, intHeight
		Me.MoveTo ((Screen.Width / 2) - (intWidth / 2)),((Screen.Height / 2) - (intHeight / 2))
		span_computername.innerHTML = GetComputerName()
		span_logonserver.innerHTML = GetLogonServer()
		span_Bios.innerHTML = GetBios()
		strIPInfo = GetIPInformation()
		If InStr(strIPInfo, ";") > 0 Then
			arrIPInfo = Split(strIPInfo, ";")
			If UBound(arrIPInfo) >= 3 Then
				span_ipaddress.InnerHTML = arrIPInfo(0)
				span_subnetmask.InnerHTML = arrIPInfo(1)
				span_defaultgateway.InnerHTML = arrIPInfo(2)
				span_primarydns.InnerHTML = arrIPInfo(3)
			End If
		End If
		span_Dominio.innerHTML = GetDomain()
		span_PCType.InnerHTML = GetChassitype()
	End Sub
	Function GetComputerName()
		Set objNetwork = CreateObject("WScript.Network")
		GetComputerName = objNetwork.ComputerName
	End Function
	Function GetLogonServer()
		Dim WSHShell,strRegKey 
		Set WSHShell = CreateObject("WScript.Shell") 
		strRegKey="HKCU\Volatile Environment\LogonServer" 
		GetLogonServer = WSHShell.RegRead(strRegKey) 
	End Function
	Function GetIPInformation()
		strComputer = "."
		Set objWMIService = GetObject("winmgmts:\\" & strComputer & "\root\cimv2")
		Set colNetAdapters = objWMIService.ExecQuery("Select * from Win32_NetworkAdapterConfiguration Where IPEnabled=True")
		strDetails = ""
		For Each objAdapter In colNetAdapters
			If IsNull(objAdapter.IPAddress) = False And IsNull(objAdapter.DefaultIPGateway) = False Then
				If Join(objAdapter.IPAddress) <> "0.0.0.0" Then
					If strDetails = "" Then
						strDetails = Join(objAdapter.IPAddress) & ";"
						strDetails = strDetails & Join(objAdapter.IPSubnet) & ";"
						strDetails = strDetails & Join(objAdapter.DefaultIPGateway) & ";"
						strDetails = strDetails & Join(objAdapter.DNSServerSearchOrder, ";")
					End If
				End If
			End If
		Next
		GetIPInformation = strDetails
	End Function
    Function GetBios()
	strComputer = "."
	Set objWMIService = GetObject("winmgmts:\\" & strComputer & "\root\cimv2")
	Set BIOSItems = objWMIService.ExecQuery("SELECT * FROM Win32_BIOS")
	For Each objItem In BIOSItems
		strBIOS=Trim(objItem.Manufacturer)
		strSerialNum=Trim(objItem.SerialNumber)
	Next
	GetBios = strBIOS
	span_serialnum.innerText = strSerialNum
	End Function
	Function GetDomain()
	On Error Resume Next
	Const wbemFlagReturnImmediately = &h10
	Const wbemFlagForwardOnly = &h20
	strComputer = "."
		   Set objWMIService = GetObject("winmgmts:\\" & strComputer & "\root\CIMV2")
		   Set colItems = objWMIService.ExecQuery("SELECT * FROM Win32_ComputerSystem", "WQL",wbemFlagReturnImmediately + wbemFlagForwardOnly)
		   For Each objItem In colItems
		      strDomain = objItem.Domain
		      strmodelo = objItem.Model
		      strUsername = objItem.UserName
		   Next
	span_username.innerHTML = strUsername
	span_modelo.innerHTML = strmodelo
	GetDomain = strDomain
	End Function
	Function GetChassitype()
	strComputer = "."
	Set objWMIService = GetObject("winmgmts:\\" & strComputer & "\root\CIMV2")
	Set ChassisItems = objWMIService.ExecQuery("Select ChassisTypes from Win32_SystemEnclosure")
	For Each objItem In ChassisItems
		For j = Lbound(objItem.ChassisTypes) To UBound(objItem.ChassisTypes)
			varChassisType = objItem.ChassisTypes(j)
		Next
		Select Case varChassisType
			Case 1: strChassisType = "Other"
			Case 2: strChassisType = "Unknown"
			Case 3: strChassisType = "Desktop"
			Case 4: strChassisType = "Low-profile desktop"
			Case 5: strChassisType = "Pizza box"
			Case 6: strChassisType = "Mini tower"
			Case 7: strChassisType = "Tower"
			Case 8: strChassisType = "Portable"
			Case 9: strChassisType = "Laptop"
			Case 10: strChassisType = "Notebook"
			Case 11: strChassisType = "Hand-held"
			Case 12: strChassisType = "Docking station"
			Case 13: strChassisType = "All-in-one"
			Case 14: strChassisType = "Subnotebook"
			Case 15: strChassisType = "Space-saving"
			Case 16: strChassisType = "Lunch box"
			Case 17: strChassisType = "Main system chassis"
			Case 18: strChassisType = "Expansion chassis"
			Case 19: strChassisType = "Subchassis"
			Case 20: strChassisType = "Bus-expansion chassis"
			Case 21: strChassisType = "Peripheral chassis"
			Case 22: strChassisType = "Storage chassis"
			Case 23: strChassisType = "Rack-mounted chassis"
			Case 24: strChassisType = "Sealed-case computer"
	 	End Select
 	Next
	GetChassitype = strChassisType
	End Function	
Function StrDateTime(d)
	Dim strVal,strDate,strTime
	strVal = CStr(d)
	strDate = DateSerial(Left(strVal, 4), Mid(strVal, 5, 2), Mid(strVal, 7, 2))
	strTime = TimeSerial(Mid(strVal, 9, 2), Mid(strVal, 11, 2), Mid(strVal, 13, 2))
	StrDateTime = strDate + strTime
End Function	
	Sub Exit_HTA
		window.close
	End Sub
	Set objNetwork = CreateObject("WScript.Network")
	strUsername = objNetwork.UserName
	strDomainName = objNetwork.UserDomain
	strCompName = UCase(objNetwork.ComputerName)
	Set objLDAPUser = GetObject("LDAP://" & GetUserDN(strUsername,strDomainName))	
	Function GetUserDN(BYVAL UN, BYVAL DN)
	Set objTrans = CreateObject("NameTranslate")
		objTrans.init 1, DN
		objTrans.set 3, DN & "\" & UN
		strUserDN = objTrans.Get(1)
		GetUserDN = strUserDN
	End Function
	Sub enviar_email		
    Set OutApp = CreateObject("Outlook.Application")
    Set OutMail = OutApp.CreateItem(0)
        With OutMail
            .To = "support@yourcompany.com"
            .Subject = "" & UCase(strCompName) & " | " & objLDAPUser.DisplayName & " | Resumo:"
            .Body = "Informações automáticas:(não apagar)" & vbCrLf & "---Nome do PC: " & UCase(strCompName) & vbCrLf & "---Utilizador: " & objLDAPUser.DisplayName & vbCrLf & "#relate " & UCase(strCompName) & vbCrLf & vbCrLf & "Descreva da melhor forma o seu problema, caso necessário anexe imagens." & vbCrLf & "Obrigado" & vbCrLf & vbCrLf & "Problema:"
            .Display
        End With
        On Error GoTo 0
        Set OutMail = Nothing
        Set OutApp = Nothing	
	End Sub
</script>
</head>
<body>
<table align="center" border="0" cellpadding="0" cellspacing="0" width="650">
<tr valign="top">
  <td align="right" colspan="2">
    <span class="creator-link">Created by <a href="https://github.com/nelsondcosta23/HTA-IT-Support" target="_blank">Nelson Costa</a></span>
  </td>
</tr>
<tr valign="top">
  <td colspan="2">
    &nbsp; <span class="tabs tabs1" id="tab1" onclick="panel(1)">Geral</span>
    &nbsp; <span class="tabs tabs0" id="tab2" onclick="panel(2)">Rede</span>
    &nbsp; <span class="tabs tabs0" id="tab3" onclick="panel(3)">Hardware</span>
    &nbsp; <span class="tabs tabs0" id="tab4" onclick="panel(4)">Software</span>
    <div class="panel" id="panel1" style="display:block">
      <hr color="black">
        <table border="0" width="100%">
        <tr valign="top">
          <td>
            <table align="center" border="0" width="100%">
	<tr><td style="height: 30px" class="style2">IT Support Department</td></tr>
	<tr><td class="style3">Leave <a href="mailto:support@yourcompany.com?Subject=Support%20Suggestions" target="_top">here</a> your suggestions.</td></tr>
</table>
<table width= "90%" border="0" align="center">
		<tr><td>Nome do Computador:</td><td><span><script type="text/javascript"> document.write(computername());</script></span></td></tr>
		<tr><td>Conta de Utilizador:</td><td><span><script type="text/javascript"> document.write(username());</script></span></td></tr>
		<tr><td>IP:</td><td><span><script type="text/javascript"> document.write(ip);</script></span></td></tr>
		<tr><td>MAC Ligado:</td><td><span><script type="text/javascript"> document.write(mac);</script></span></td></tr>
</table>
<hr>
<center>	
<table width= "90%" border="0" align="center">
	<tr><td><button class="button button5" onclick="link1()" value="1">Botão 1</button></td><td><button class="button button5" onclick="link2()" value="2">Botão 2</button></td></tr>
	<tr><td><button class="button button5" onclick="link3()" value="3">Botão 3</button></td><td><button class="button button5" onclick="link4()" value="4">Botão 4</button></td></tr>
	<tr><td><button class="button button5" onclick="link5()" value="5">Botão 5</button></td><td><button class="button button5" onclick="link6()" value="6">Botão 6</button></td></tr>
	<tr><td><button class="button button5" onclick="link7()" value="7">Botão 7</button></td><td><button class="button button5" onclick="link8()" value="8">Botão 8</button></td></tr>
</table>
</center>
	<br>
	<table width= "100%" border="0" align="center">
		<tr align="center">
			<td>
				<button class="button button1" name="btn_ticket" id="btn_ticket" accessKey="c" onclick="vbs:enviar_email">CRIAR TICKET</button>
				&nbsp;	&nbsp;	&nbsp;
				<button class="button button1" name="btn_exit" id="btn_exit" accessKey="x" onclick="vbs:Exit_HTA">SAIR</button>
			</td>
		</tr>
	</table>
          </td>
        </tr>
        </table>
    </div>
    <div class="panel" id="panel3" style="display:none">
      <hr color="black">
        <table border="0" width="100%">
        <tr valign="top">
          <td>
            <tr><td class="style1">HARDWARE</td><td class="style1">&nbsp;</td></tr>
			<tr><td>Fabricante:</td><td><span id="span_Bios"></span></td></tr>
			<tr><td>Modelo:</td><td><span id="span_modelo"></span>&nbsp;</td></tr>
			<tr><td>Número de Serie:</td><td><span id="span_serialnum"></span></td></tr>
			<tr><td>Tipo:</td><td><span id="span_PCType"></span>&nbsp;</td></tr>
          </td>
        </tr>
        </table>
    </div>
    <div class="panel" id="panel4" style="display:none">
      <hr color="black">
        <table border="0" width="100%">
        <tr valign="top">
        <td>
		<tr><td class="style1">SOFTWARE</td></tr>
		</td>
        </tr>
        </table>
		<div id=DataAreaNL></div>
			<SCRIPT Language="VBScript">
			Set dtmConvertedDate = CreateObject("WbemScripting.SWbemDateTime")
			strComputer = "."
			Set objWMIService = GetObject("winmgmts:" & "{impersonationLevel=impersonate}!\\" & strComputer & "\root\cimv2")
			Set colOperatingSystems = objWMIService.ExecQuery("Select * from Win32_OperatingSystem")
			For Each objOperatingSystem in colOperatingSystems
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML &"Windows: " & objOperatingSystem.Caption & "<br>"
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML &"Compilação do SO: " & objOperatingSystem.BuildNumber & "<br>"
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML &"Versão: " & objOperatingSystem.Version & "<br>"
			dtmConvertedDate.Value = objOperatingSystem.InstallDate
			dtmInstallDate = dtmConvertedDate.GetVarDate
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML &"Data de Instalação: " & dtmInstallDate  & "<br>"
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML &"Utilizador de Instalação: " & objOperatingSystem.RegisteredUser & "<br>"
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML &"Numero de Série: " & objOperatingSystem.SerialNumber & "<br>"
			Next
			Set WshShell = CreateObject("WScript.Shell")
			OsType = WshShell.RegRead("HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Environment\PROCESSOR_ARCHITECTURE")
			If OsType = "x86" then
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML & "Arquitectura: 32bit detectado" & "<BR>"
			elseif OsType = "AMD64" then
			DataAreaNL.InnerHTML=DataAreaNL.InnerHTML & "Arquitectura: 64bit detectado" & "<BR>"
			end if
			</SCRIPT>
    </div>
    <div class="panel" id="panel2" style="display:none">
      <hr color="black">
        <table border="0" width="100%">
        <tr valign="top">
          <td>
            <table width= "100%" border="0" align="center">
			<tr>
			<td>Nome de Computador:</td>
			<td><span id="span_computername"></span></td>
			</td>
		
			<tr>
			<td>Conta de Utilizador:</td>
			<td><span id="span_username"></span></td>
			</tr>
			
			<tr>
			<td>Domínio:</td>
			<td><span id="span_Dominio">&nbsp;</td>
			</tr>
			
			<tr>
			<td>Servidor Logon:<td>
				<span id="span_logonserver">&nbsp;</td>
			</tr>
			
			<tr>
			<td>Endereço IP:</td>
			<td><span id="span_ipaddress"></span></td>
			</tr>
			
			<tr>
			<td>Mascara de Rede:</td>
			<td><span id="span_subnetmask"></span></td>
			</tr>
			
			<tr>
			<td>Gateway:</td>
			<td><span id="span_defaultgateway"></span></td>
			</tr>
			
			<tr>
			<td>DNS Primário:</td>
			<td><span id="span_primarydns"></span></td>
			</tr>
			
			<tr>
			<td>DNS Secundário:</td>
			<td><span id="span_secondarydns"></span></td>
			</tr>
        </table>
    </div>

  </td>
</tr>
</table>
</body>
</html>